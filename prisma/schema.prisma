// Multi-site Affiliate Blog CMS Schema
// Supports multiple sites from a single database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Multi-site support - each site can have its own branding and content
model Site {
  id          String   @id @default(cuid())
  name        String   @unique
  domain      String?  @unique
  description String
  logo        String?
  
  // Branding
  primaryColor    String @default("#b7004f")
  secondaryColor  String @default("#5f5c6f")
  
  // SEO
  metaTitle       String?
  metaDescription String?
  
  // Social links
  facebook   String?
  twitter    String?
  instagram  String?
  linkedin   String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  authors     Author[]
  categories  Category[]
  posts       Post[]
  pages       Page[]
  menus       Menu[]
  settings    SiteSetting[]
}

model Author {
  id        String @id @default(cuid())
  name      String
  email     String?
  avatar    String?
  bio       String?
  website   String?
  
  // Social profiles
  twitter   String?
  facebook  String?
  
  siteId    String
  site      Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  posts     Post[]
}

model Category {
  id          String @id @default(cuid())
  name        String
  slug        String
  description String?
  color       String @default("#b7004f") // Badge color
  
  siteId      String
  site        Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  posts       Post[]
  
  @@unique([siteId, slug])
}

model Tag {
  id          String @id @default(cuid())
  name        String
  slug        String
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  posts       PostTag[]
  
  @@unique([slug])
}

model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String
  excerpt     String?
  content     String   // MDX or HTML content
  
  // Media
  imageUrl    String
  imageAlt    String?
  
  // SEO
  metaTitle       String?
  metaDescription String?
  
  // Status
  published       Boolean  @default(false)
  featured        Boolean  @default(false)
  publishedAt     DateTime?
  
  // Affiliate tracking
  affiliateLinks  String?  // JSON array of affiliate links
  
  // Layout options
  layout      String   @default("default") // default, fullwidth, sidebar-left
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  
  authorId    String
  author      Author   @relation(fields: [authorId], references: [id])
  
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  
  tags        PostTag[]
  
  @@unique([siteId, slug])
}

model PostTag {
  postId    String
  tagId     String
  
  post      Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag       Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  @@id([postId, tagId])
}

// Static pages (About, Privacy Policy, etc.)
model Page {
  id          String   @id @default(cuid())
  title       String
  slug        String
  content     String
  
  // SEO
  metaTitle       String?
  metaDescription String?
  
  published       Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  
  @@unique([siteId, slug])
}

// Navigation menus
model Menu {
  id          String   @id @default(cuid())
  name        String   // e.g., "header", "footer"
  items       String   // JSON array of menu items
  
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([siteId, name])
}

// Site-wide settings (key-value store)
model SiteSetting {
  id          String   @id @default(cuid())
  key         String
  value       String
  
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  
  @@unique([siteId, key])
}
