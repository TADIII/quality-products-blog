# Production Environment Variables
# Copy this file to .env.production for production builds

# ===================
# Database Configuration
# ===================

# SQLite (for Docker/VPS)
DATABASE_URL="file:./db/production.db"

# PostgreSQL (for Vercel/Railway/Render)
# DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# ===================
# Application Settings
# ===================

# Node environment
NODE_ENV="production"

# Site URL (optional - for absolute URLs)
# NEXT_PUBLIC_SITE_URL="https://yourdomain.com"

# ===================
# Analytics (Optional)
# ===================

# Google Analytics
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# ===================
# Authentication (Optional - for admin)
# ===================

# NextAuth.js
# NEXTAUTH_SECRET="your-super-secret-key-here"
# NEXTAUTH_URL="https://yourdomain.com"

# ===================
# Email (Optional)
# ===================

# SMTP Settings for newsletter
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="your-email"
# SMTP_PASS="your-password"
